# Postgres connection (per-app role in the meizuno stack: calories_user).
DATABASE_URL=postgres://calories_user:password@localhost:5432/calories?sslmode=disable

# HTTP port (default).
PORT=8080

# Dev fallback identity when no SSO token is present (local use).
DEV_USER_ID=00000000-0000-0000-0000-000000000001

# meizuno SSO: when set, the auth middleware validates the access_token cookie
# against the auth service and uses the returned user_id. Empty = dev fallback.
AUTH_VALIDATE_URL=
